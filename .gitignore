# Terraform state — never commit, contains sensitive outputs and resource IDs
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directories — restored by `terraform init`
**/.terraform/

# Variable files — may contain real credentials
*.tfvars
*.tfvars.json

# Terraform crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Claude Code session files
.claude/

# Editor swap and temp files
*.swp
*.swo
*~
.DS_Store
# Ignore ad-hoc/scratch shell scripts by default...
*.sh
# ...but the scripts/ dir holds deploy-critical helpers Terraform + the Makefile
# call locally (retry, CRD readiness gates, gatekeeper priming). A fresh clone
# needs them, so keep them tracked.
!scripts/*.sh
CLAUDE*
RESULTS*
# Transient deploy log written by `make deploy` redirection
deploy.log
# Python cache
__pycache__/
*.pyc

# floci (local AWS emulator) persistent data — contains Secrets Manager values,
# KMS material, and other local state. Never commit.
floci-data/

# Security-gate run evidence (uploaded as CI artifacts; not committed)
security/reports/
